<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="SauceDemo Automation Suite"
       parallel="tests"
       thread-count="3">

    <!-- 🔔 Listeners -->
    <listeners>
        <listener class-name="listeners.ExtentListener"/>
    </listeners>

    <!-- 🔐 Login Tests -->
    <test name="Login Tests">
        <classes>
            <class name="tests.LoginNegativeTest"/>
        </classes>
    </test>

    <!-- 🛒 Inventory Tests -->
    <test name="Inventory Tests">
        <classes>
            <class name="tests.InventoryTest"/>
        </classes>
    </test>

    <!-- 🛍 Cart Tests -->
    <test name="Cart Tests">
        <classes>
            <class name="tests.CartTest"/>
        </classes>
    </test>

    <!-- 💳 Checkout Tests -->
    <test name="Checkout Tests">
        <classes>
            <class name="tests.CheckoutNegativeTest"/>
            <class name="tests.EndToEndSauceDemoTest"/>
        </classes>
    </test>

</suite>
